{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClickHouse Cluster Helm Chart Values",
  "description": "Schema for validating values.yaml of the clickhouse-cluster Helm chart.",
  "type": "object",
  "properties": {
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name used in resource metadata."
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full release name used in resource metadata."
    },
    "keeperFullnameOverride": {
      "type": "string",
      "description": "Override the KeeperCluster CR name. Defaults to the release name."
    },
    "commonLabels": {
      "type": "object",
      "description": "Common labels applied to all resources.",
      "additionalProperties": { "type": "string" }
    },
    "commonAnnotations": {
      "type": "object",
      "description": "Common annotations applied to all resources.",
      "additionalProperties": { "type": "string" }
    },
    "clickhouseCluster": {
      "type": "object",
      "description": "ClickHouseCluster custom resource configuration.",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to create the ClickHouseCluster CR.",
          "default": true
        },
        "labels": {
          "type": "object",
          "description": "Additional labels for the ClickHouseCluster resource.",
          "additionalProperties": { "type": "string" }
        },
        "annotations": {
          "type": "object",
          "description": "Additional annotations for the ClickHouseCluster resource.",
          "additionalProperties": { "type": "string" }
        },
        "clusterDomain": {
          "type": "string",
          "description": "Kubernetes cluster domain suffix.",
          "default": "cluster.local"
        },
        "shards": {
          "type": "integer",
          "description": "Number of shards in the cluster.",
          "minimum": 0,
          "default": 1
        },
        "replicas": {
          "type": "integer",
          "description": "Number of replicas per shard.",
          "minimum": 0,
          "default": 2
        },
        "upgradeChannel": {
          "type": "string",
          "description": "Release channel for upgrades: '', 'lts', 'stable', or 'X.Y'.",
          "default": ""
        },
        "keeperClusterRef": {
          "type": "object",
          "description": "Reference to the KeeperCluster resource.",
          "properties": {
            "name": {
              "type": "string",
              "description": "Name of the KeeperCluster. Auto-derived if empty and keeperCluster.enabled."
            }
          },
          "additionalProperties": false
        },
        "containerTemplate": {
          "type": "object",
          "description": "ClickHouse container spec parameters.",
          "properties": {
            "image": {
              "type": "object",
              "description": "Container image configuration.",
              "properties": {
                "repository": {
                  "type": "string",
                  "description": "Image repository."
                },
                "tag": {
                  "type": "string",
                  "description": "Image tag."
                },
                "pullPolicy": {
                  "type": "string",
                  "description": "Image pull policy.",
                  "enum": ["Always", "IfNotPresent", "Never"],
                  "default": "IfNotPresent"
                }
              },
              "additionalProperties": false
            },
            "resources": {
              "type": "object",
              "description": "CPU and memory resource requests and limits.",
              "properties": {
                "requests": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "limits": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              },
              "additionalProperties": false
            },
            "env": {
              "type": "array",
              "description": "Environment variables.",
              "items": { "type": "object" }
            },
            "securityContext": {
              "type": "object",
              "description": "Container-level security context."
            },
            "volumeMounts": {
              "type": "array",
              "description": "Additional volume mounts.",
              "items": { "type": "object" }
            }
          },
          "additionalProperties": false
        },
        "dataVolumeClaimSpec": {
          "type": "object",
          "description": "PVC spec for ClickHouse data storage.",
          "properties": {
            "accessModes": {
              "type": "array",
              "description": "Volume access modes.",
              "items": {
                "type": "string",
                "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany", "ReadWriteOncePod"]
              },
              "default": ["ReadWriteOnce"]
            },
            "storageClassName": {
              "type": "string",
              "description": "Storage class name."
            },
            "resources": {
              "type": "object",
              "description": "Storage resource requests.",
              "properties": {
                "requests": {
                  "type": "object",
                  "properties": {
                    "storage": {
                      "type": "string",
                      "description": "Volume size.",
                      "default": "100Gi"
                    }
                  },
                  "required": ["storage"]
                }
              },
              "required": ["requests"]
            }
          },
          "additionalProperties": false
        },
        "podDisruptionBudget": {
          "type": "object",
          "description": "Pod disruption budget configuration.",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "minAvailable": {
              "type": ["string", "integer"],
              "description": "Minimum available pods."
            },
            "maxUnavailable": {
              "type": ["string", "integer"],
              "description": "Maximum unavailable pods."
            },
            "policy": {
              "type": "string",
              "enum": ["Enabled", "Disabled", "Ignored"],
              "default": "Enabled"
            },
            "unhealthyPodEvictionPolicy": {
              "type": "string",
              "description": "Eviction policy for unhealthy pods."
            }
          },
          "additionalProperties": false
        },
        "podTemplate": {
          "type": "object",
          "description": "Pod-level configuration.",
          "properties": {
            "affinity": { "type": "object" },
            "nodeSelector": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "tolerations": {
              "type": "array",
              "items": { "type": "object" }
            },
            "topologySpreadConstraints": {
              "type": "array",
              "items": { "type": "object" }
            },
            "priorityClassName": { "type": "string" },
            "securityContext": { "type": "object" },
            "imagePullSecrets": {
              "type": "array",
              "items": { "type": "object" }
            },
            "initContainers": {
              "type": "array",
              "items": { "type": "object" }
            },
            "volumes": {
              "type": "array",
              "items": { "type": "object" }
            },
            "terminationGracePeriodSeconds": {
              "type": "integer",
              "minimum": 0,
              "default": 60
            }
          },
          "additionalProperties": false
        },
        "settings": {
          "type": "object",
          "description": "ClickHouse server settings.",
          "properties": {
            "enableDatabaseSync": {
              "type": "boolean",
              "default": true
            },
            "defaultUserPassword": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "passwordType": {
                  "type": "string",
                  "enum": [
                    "password",
                    "plaintext_password",
                    "sha256_password",
                    "double_sha1_password",
                    "bcrypt_password"
                  ],
                  "default": "sha256_password"
                },
                "secret": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "key": { "type": "string", "default": "password" }
                  },
                  "additionalProperties": false
                },
                "configMap": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "key": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            },
            "logger": {
              "type": "object",
              "properties": {
                "level": {
                  "type": "string",
                  "enum": ["test", "trace", "debug", "information", "notice", "warning", "error", "critical", "fatal"],
                  "default": "information"
                },
                "logToFile": {
                  "type": "boolean",
                  "default": true
                },
                "size": {
                  "type": "string",
                  "default": "1000M"
                },
                "count": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 50
                },
                "jsonLogs": {
                  "type": "boolean",
                  "default": false
                }
              },
              "additionalProperties": false
            },
            "tls": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "required": {
                  "type": "boolean",
                  "default": false
                },
                "serverCertSecret": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "key": { "type": "string" }
                  },
                  "additionalProperties": false
                },
                "caBundle": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "key": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            },
            "extraConfig": {
              "type": "object",
              "description": "Extra ClickHouse server configuration."
            },
            "extraUsersConfig": {
              "type": "object",
              "description": "Extra ClickHouse users configuration."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "keeperCluster": {
      "type": "object",
      "description": "KeeperCluster custom resource configuration.",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to create the KeeperCluster CR.",
          "default": true
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "clusterDomain": {
          "type": "string",
          "default": "cluster.local"
        },
        "replicas": {
          "type": "integer",
          "description": "Number of Keeper replicas. Must be odd for quorum.",
          "enum": [0, 1, 3, 5, 7, 9, 11, 13, 15],
          "default": 3
        },
        "upgradeChannel": {
          "type": "string",
          "default": ""
        },
        "containerTemplate": {
          "type": "object",
          "properties": {
            "image": {
              "type": "object",
              "properties": {
                "repository": { "type": "string" },
                "tag": { "type": "string" },
                "pullPolicy": {
                  "type": "string",
                  "enum": ["Always", "IfNotPresent", "Never"],
                  "default": "IfNotPresent"
                }
              },
              "additionalProperties": false
            },
            "resources": {
              "type": "object",
              "properties": {
                "requests": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "limits": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              },
              "additionalProperties": false
            },
            "env": {
              "type": "array",
              "items": { "type": "object" }
            },
            "securityContext": { "type": "object" },
            "volumeMounts": {
              "type": "array",
              "items": { "type": "object" }
            }
          },
          "additionalProperties": false
        },
        "dataVolumeClaimSpec": {
          "type": "object",
          "properties": {
            "accessModes": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany", "ReadWriteOncePod"]
              }
            },
            "storageClassName": { "type": "string" },
            "resources": {
              "type": "object",
              "properties": {
                "requests": {
                  "type": "object",
                  "properties": {
                    "storage": { "type": "string" }
                  },
                  "required": ["storage"]
                }
              },
              "required": ["requests"]
            }
          },
          "additionalProperties": false
        },
        "podDisruptionBudget": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "minAvailable": { "type": ["string", "integer"] },
            "maxUnavailable": { "type": ["string", "integer"] },
            "policy": {
              "type": "string",
              "enum": ["Enabled", "Disabled", "Ignored"],
              "default": "Enabled"
            },
            "unhealthyPodEvictionPolicy": { "type": "string" }
          },
          "additionalProperties": false
        },
        "podTemplate": {
          "type": "object",
          "properties": {
            "affinity": { "type": "object" },
            "nodeSelector": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "tolerations": {
              "type": "array",
              "items": { "type": "object" }
            },
            "topologySpreadConstraints": {
              "type": "array",
              "items": { "type": "object" }
            },
            "priorityClassName": { "type": "string" },
            "securityContext": { "type": "object" },
            "imagePullSecrets": {
              "type": "array",
              "items": { "type": "object" }
            },
            "initContainers": {
              "type": "array",
              "items": { "type": "object" }
            },
            "volumes": {
              "type": "array",
              "items": { "type": "object" }
            },
            "terminationGracePeriodSeconds": {
              "type": "integer",
              "minimum": 0,
              "default": 30
            }
          },
          "additionalProperties": false
        },
        "settings": {
          "type": "object",
          "properties": {
            "logger": {
              "type": "object",
              "properties": {
                "level": {
                  "type": "string",
                  "enum": ["test", "trace", "debug", "information", "notice", "warning", "error", "critical", "fatal"],
                  "default": "information"
                },
                "logToFile": { "type": "boolean", "default": true },
                "size": { "type": "string", "default": "1000M" },
                "count": { "type": "integer", "minimum": 0, "default": 50 },
                "jsonLogs": { "type": "boolean", "default": false }
              },
              "additionalProperties": false
            },
            "tls": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean", "default": false },
                "required": { "type": "boolean", "default": false },
                "serverCertSecret": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "key": { "type": "string" }
                  },
                  "additionalProperties": false
                },
                "caBundle": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "key": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            },
            "extraConfig": {
              "type": "object",
              "description": "Extra Keeper configuration."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "secrets": {
      "type": "object",
      "description": "Managed Kubernetes Secrets.",
      "properties": {
        "defaultUserPassword": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "create": { "type": "boolean", "default": true },
            "name": { "type": "string" },
            "password": { "type": "string" }
          },
          "additionalProperties": false
        },
        "tls": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "create": { "type": "boolean", "default": true },
            "name": { "type": "string" },
            "cert": { "type": "string" },
            "key": { "type": "string" },
            "caBundle": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "serviceMonitor": {
      "type": "object",
      "description": "Prometheus ServiceMonitor for ClickHouse pods.",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "namespace": { "type": "string" },
        "interval": { "type": "string", "default": "30s" },
        "scrapeTimeout": { "type": "string", "default": "10s" },
        "port": { "type": "string", "default": "metrics" },
        "path": { "type": "string", "default": "/metrics" },
        "scheme": {
          "type": "string",
          "enum": ["http", "https"],
          "default": "http"
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "relabelings": { "type": "array", "items": { "type": "object" } },
        "metricRelabelings": { "type": "array", "items": { "type": "object" } },
        "tlsConfig": { "type": "object" },
        "selector": { "type": "object" }
      },
      "additionalProperties": false
    },
    "keeperServiceMonitor": {
      "type": "object",
      "description": "Prometheus ServiceMonitor for Keeper pods.",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "namespace": { "type": "string" },
        "interval": { "type": "string", "default": "30s" },
        "scrapeTimeout": { "type": "string", "default": "10s" },
        "port": { "type": "string", "default": "metrics" },
        "path": { "type": "string", "default": "/metrics" },
        "scheme": {
          "type": "string",
          "enum": ["http", "https"],
          "default": "http"
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "relabelings": { "type": "array", "items": { "type": "object" } },
        "metricRelabelings": { "type": "array", "items": { "type": "object" } },
        "tlsConfig": { "type": "object" },
        "selector": { "type": "object" }
      },
      "additionalProperties": false
    },
    "prometheusRule": {
      "type": "object",
      "description": "PrometheusRule alert rules.",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "namespace": { "type": "string" },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "defaultRules": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true }
          },
          "additionalProperties": false
        },
        "additionalRules": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "additionalProperties": false
    },
    "grafanaDashboard": {
      "type": "object",
      "description": "Grafana dashboard ConfigMap.",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "folder": { "type": "string" },
        "dashboardJson": { "type": "string" }
      },
      "additionalProperties": false
    },
    "networkPolicy": {
      "type": "object",
      "description": "Kubernetes NetworkPolicy configuration.",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "policyTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Ingress", "Egress"]
          }
        },
        "ingress": {
          "type": "object",
          "properties": {
            "fromNamespaces": { "type": "array", "items": { "type": "object" } },
            "fromPodSelector": { "type": "object" },
            "allowKeeper": { "type": "boolean", "default": true }
          },
          "additionalProperties": false
        },
        "egress": {
          "type": "object",
          "properties": {
            "toCIDRs": {
              "type": "array",
              "items": { "type": "string" }
            },
            "allowDNS": { "type": "boolean", "default": true }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "extraManifests": {
      "type": "array",
      "description": "Extra manifests to deploy.",
      "items": { "type": "string" }
    },
    "tests": {
      "type": "object",
      "description": "Helm test configuration.",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "additionalProperties": false
        },
        "keeperImage": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
